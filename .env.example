# Used by ./gradlew bootRun (local development)
DB_URL=jdbc:mysql://localhost:3306/chatapp?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Used by Docker Compose (docker-compose.yml overrides DB_URL to point to the db service)
# DB_URL=jdbc:mysql://db:3306/chatapp?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
